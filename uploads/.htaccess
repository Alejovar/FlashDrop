# Bloquear listado de directorios
Options -Indexes

# Solo JPEG permitido desde este directorio (los originales)
<FilesMatch "\.jpg$">
    Header set X-Content-Type-Options "nosniff"
</FilesMatch>

# Bloquear cualquier cosa que no sea JPEG o el .htaccess
<FilesMatch "^(?!.*\.(jpg|htaccess)$)">
    Require all denied
</FilesMatch>

# NO permitir ejecución de PHP en uploads
php_flag engine off

# Bloquear acceso al directorio de originales desde fuera (solo via PHP)
# Los invitados solo descargan via api/polaroid.php, nunca directamente
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^originals/.+$ - [F,L]
</IfModule>
